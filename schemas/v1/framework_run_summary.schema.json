{
  "id": "framework_run_summary/v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_dir",
    "metrics_path",
    "model",
    "attack",
    "defense",
    "seed"
  ],
  "properties": {
    "schema_version": {
      "const": "framework_run_summary/v1"
    },
    "model": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "attack": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "defense": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "reporting_context": {
      "type": "object",
      "properties": {
        "run_role": {
          "type": "string",
          "enum": [
            "baseline",
            "attack_only",
            "defended",
            "tune",
            "consistency"
          ]
        },
        "dataset_scope": {
          "type": "string",
          "enum": [
            "smoke",
            "tune",
            "full"
          ]
        },
        "authority": {
          "type": "string",
          "enum": [
            "diagnostic",
            "authoritative"
          ]
        },
        "source_phase": {
          "type": "string",
          "enum": [
            "phase1",
            "phase2",
            "phase3",
            "phase4",
            "manual"
          ]
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "description": "Optional per-phase wall-clock timing, timestamps, and runtime environment.",
      "properties": {
        "started_at_utc": {"type": ["string", "null"]},
        "finished_at_utc": {"type": ["string", "null"]},
        "total_ms": {"type": ["number", "null"]},
        "attack_ms": {"type": ["number", "null"]},
        "defense_preprocess_ms": {"type": ["number", "null"]},
        "image_write_ms": {"type": ["number", "null"]},
        "predict_ms": {"type": ["number", "null"]},
        "defense_postprocess_ms": {"type": ["number", "null"]},
        "validation_ms": {"type": ["number", "null"]},
        "artifact_write_ms": {"type": ["number", "null"]},
        "python_version": {"type": ["string", "null"]},
        "platform": {"type": ["string", "null"]},
        "device_hint": {"type": ["string", "null"]}
      }
    }
  }
}
