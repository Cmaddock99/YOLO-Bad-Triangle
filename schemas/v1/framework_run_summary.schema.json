{
  "id": "framework_run_summary/v1",
  "type": "object",
  "required": [
    "schema_version",
    "run_dir",
    "metrics_path",
    "model",
    "attack",
    "defense",
    "seed"
  ],
  "properties": {
    "schema_version": {
      "const": "framework_run_summary/v1"
    },
    "model": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "attack": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "defense": {
      "type": "object",
      "required": [
        "name"
      ]
    },
    "reporting_context": {
      "type": "object",
      "properties": {
        "run_role": {
          "type": "string",
          "enum": [
            "baseline",
            "attack_only",
            "defended",
            "tune",
            "consistency"
          ]
        },
        "dataset_scope": {
          "type": "string",
          "enum": [
            "smoke",
            "tune",
            "full"
          ]
        },
        "authority": {
          "type": "string",
          "enum": [
            "diagnostic",
            "authoritative"
          ]
        },
        "source_phase": {
          "type": "string",
          "enum": [
            "phase1",
            "phase2",
            "phase3",
            "phase4",
            "manual"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
