{
  "id": "framework_metrics/v1",
  "type": "object",
  "required": [
    "schema_version",
    "predictions",
    "validation"
  ],
  "properties": {
    "schema_version": {
      "const": "framework_metrics/v1"
    },
    "predictions": {
      "type": "object",
      "required": [
        "image_count",
        "images_with_detections",
        "total_detections"
      ],
      "properties": {
        "per_class": {
          "type": "object",
          "description": "Per-class detection counts and confidence (optional, keyed by string class ID)",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "count": {"type": "integer"},
              "mean_confidence": {"type": ["number", "null"]},
              "class_name": {"type": "string"}
            }
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "status",
        "enabled"
      ]
    },
    "runtime": {
      "type": "object",
      "description": "Optional per-phase wall-clock timing and timestamps.",
      "properties": {
        "started_at_utc": {"type": ["string", "null"]},
        "finished_at_utc": {"type": ["string", "null"]},
        "total_ms": {"type": ["number", "null"]},
        "attack_ms": {"type": ["number", "null"]},
        "defense_preprocess_ms": {"type": ["number", "null"]},
        "image_write_ms": {"type": ["number", "null"]},
        "predict_ms": {"type": ["number", "null"]},
        "defense_postprocess_ms": {"type": ["number", "null"]},
        "validation_ms": {"type": ["number", "null"]},
        "artifact_write_ms": {"type": ["number", "null"]}
      }
    }
  }
}
