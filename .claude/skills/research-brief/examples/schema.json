{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "research-brief output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill",
    "status",
    "cycles_analyzed",
    "latest_cycle_id",
    "checkpoint_status",
    "top_findings",
    "cross_cycle_trends",
    "recommended_next",
    "warnings"
  ],
  "properties": {
    "skill": {
      "const": "research-brief"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "insufficient_data"]
    },
    "cycles_analyzed": {
      "type": "integer",
      "minimum": 1
    },
    "latest_cycle_id": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clean_validation_complete", "deployment_recommendation"],
      "properties": {
        "clean_validation_complete": {
          "type": "boolean"
        },
        "finetuned_delta_mAP50_clean": {
          "type": ["number", "null"]
        },
        "deployment_recommendation": {
          "type": "string",
          "enum": ["deploy", "conditional_pass", "do_not_deploy", "not_evaluated"]
        }
      }
    },
    "top_findings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "cross_cycle_trends": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "recommended_next": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
