{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "experiment-planner output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill",
    "status",
    "planning_basis",
    "queue",
    "blocked_by"
  ],
  "properties": {
    "skill": {
      "const": "experiment-planner"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "partial",
        "insufficient_data"
      ]
    },
    "planning_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "budget",
        "allowed_attacks",
        "allowed_defenses"
      ],
      "properties": {
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "budget": {
          "type": "string",
          "minLength": 1
        },
        "allowed_attacks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_defenses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "queue": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "priority",
          "run_name_hint",
          "params",
          "expected_value",
          "cost_estimate",
          "stop_condition",
          "risk_note"
        ],
        "properties": {
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "run_name_hint": {
            "type": "string",
            "minLength": 1
          },
          "params": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "attack",
              "defense",
              "runner.max_images",
              "validation.enabled"
            ],
            "properties": {
              "attack": {
                "type": "string",
                "minLength": 1
              },
              "defense": {
                "type": "string",
                "minLength": 1
              },
              "runner.max_images": {
                "type": "integer",
                "minimum": 0
              },
              "validation.enabled": {
                "type": "boolean"
              }
            }
          },
          "expected_value": {
            "type": "string",
            "minLength": 1
          },
          "cost_estimate": {
            "type": "string",
            "minLength": 1
          },
          "stop_condition": {
            "type": "string",
            "minLength": 1
          },
          "risk_note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "blocked_by": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
