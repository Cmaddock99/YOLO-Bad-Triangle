{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "cycle-forensics output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill",
    "cycle_path",
    "status",
    "rankings",
    "anomalies",
    "highlights"
  ],
  "properties": {
    "skill": {
      "const": "cycle-forensics"
    },
    "cycle_path": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "partial",
        "insufficient_data"
      ]
    },
    "checkpoint_context": {
      "type": "object",
      "description": "Optional. Present when eval_ab_*.json artifacts are available or A/B eval context is known.",
      "additionalProperties": false,
      "required": [
        "ab_eval_present",
        "clean_validation_present",
        "deployment_status"
      ],
      "properties": {
        "ab_eval_present": {
          "type": "boolean"
        },
        "clean_validation_present": {
          "type": "boolean"
        },
        "deployment_status": {
          "type": "string",
          "enum": [
            "not_evaluated",
            "conditional_pass",
            "pass",
            "fail"
          ]
        }
      }
    },
    "rankings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attack_damage",
        "defense_recovery"
      ],
      "properties": {
        "attack_damage": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "attack",
              "damage_pct"
            ],
            "properties": {
              "attack": {
                "type": "string",
                "minLength": 1
              },
              "damage_pct": {
                "type": "number"
              }
            }
          }
        },
        "defense_recovery": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "attack",
              "defense",
              "recovery_pct"
            ],
            "properties": {
              "attack": {
                "type": "string",
                "minLength": 1
              },
              "defense": {
                "type": "string",
                "minLength": 1
              },
              "recovery_pct": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "anomalies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "detail"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "missing_pair",
              "image_count_mismatch",
              "outlier_shift",
              "missing_data",
              "negative_recovery",
              "param_bound_hit",
              "conditional_ab_eval"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "highlights": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
