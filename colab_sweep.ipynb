  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Download COCO val2017 Subset (500 images)\n",
    "\n",
    "Downloads only the 500-image subset used by the framework.\n",
    "Colab's fast internet makes this quick (~80 MB)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, json, urllib.request\n",
    "from pathlib import Path\n",
    "from tqdm import tqdm\n",
    "\n",
    "COCO_DIR = Path('coco/val2017_subset500')\n",
    "IMG_DIR  = COCO_DIR / 'images'\n",
    "LBL_DIR  = COCO_DIR / 'labels'\n",
    "IMG_DIR.mkdir(parents=True, exist_ok=True)\n",
    "LBL_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# --- Download annotation file to discover which images are in the subset ---\n",
    "ANNO_URL  = 'http://images.cocodataset.org/annotations/annotations_trainval2017.zip'\n",
    "ANNO_FILE = Path('/tmp/annotations_trainval2017.zip')\n",
    "\n",
    "if not (COCO_DIR / 'instances_val2017_subset500.json').exists():\n",
    "    if not ANNO_FILE.exists():\n",
    "        print('Downloading COCO annotations (~241 MB)...')\n",
    "        urllib.request.urlretrieve(ANNO_URL, ANNO_FILE)\n",
    "    print('Extracting annotations...')\n",
    "    !unzip -q {ANNO_FILE} -d /tmp/coco_anno\n",
    "\n",
    "    # Load full val2017 annotations and take first 500 images\n",
    "    with open('/tmp/coco_anno/annotations/instances_val2017.json') as f:\n",
    "        full = json.load(f)\n",
    "\n",
    "    subset_images = full['images'][:500]\n",
    "    subset_ids    = {img['id'] for img in subset_images}\n",
    "    subset_annos  = [a for a in full['annotations'] if a['image_id'] in subset_ids]\n",
    "\n",
    "    subset = {**full, 'images': subset_images, 'annotations': subset_annos}\n",
    "    with open(COCO_DIR / 'instances_val2017_subset500.json', 'w') as f:\n",
    "        json.dump(subset, f)\n",
    "    print(f'Subset annotation saved: {len(subset_images)} images, {len(subset_annos)} annotations')\n",
    "\n",
    "# --- Download images ---\n",
    "with open(COCO_DIR / 'instances_val2017_subset500.json') as f:\n",
    "    subset = json.load(f)\n",
    "\n",
    "COCO_IMG_URL = 'http://images.cocodataset.org/val2017/'\n",
    "missing = [img for img in subset['images'] if not (IMG_DIR / img['file_name']).exists()]\n",
    "print(f'Images to download: {len(missing)} (already have {len(subset[\"images\"]) - len(missing)})')\n",
    "\n",
    "for img in tqdm(missing, desc='Downloading images', unit='img'):\n",
    "    dest = IMG_DIR / img['file_name']\n",
    "    urllib.request.urlretrieve(COCO_IMG_URL + img['file_name'], dest)\n",
    "\n",
    "print(f'Images ready: {len(list(IMG_DIR.iterdir()))}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Convert COCO annotations to YOLO label format\n",
    "import json\n",
    "from pathlib import Path\n",
    "\n",
    "COCO_DIR = Path('coco/val2017_subset500')\n",
    "LBL_DIR  = COCO_DIR / 'labels'\n",
    "LBL_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "with open(COCO_DIR / 'instances_val2017_subset500.json') as f:\n",
    "    data = json.load(f)\n",
    "\n",
    "# COCO category id → 0-indexed YOLO class id\n",
    "cat_map = {cat['id']: i for i, cat in enumerate(data['categories'])}\n",
    "img_map = {img['id']: img for img in data['images']}\n",
    "\n",
    "# Group annotations by image\n",
    "from collections import defaultdict\n",
    "annos_by_image = defaultdict(list)\n",
    "for anno in data['annotations']:\n",
    "    annos_by_image[anno['image_id']].append(anno)\n",
    "\n",
    "written = 0\n",
    "for img in data['images']:\n",
    "    lbl_path = LBL_DIR / (Path(img['file_name']).stem + '.txt')\n",
    "    if lbl_path.exists():\n",
    "        continue\n",
    "    W, H = img['width'], img['height']\n",
    "    lines = []\n",
    "    for anno in annos_by_image[img['id']]:\n",
    "        if anno.get('iscrowd', 0):\n",
    "            continue\n",
    "        x, y, w, h = anno['bbox']  # COCO: top-left x,y + width,height\n",
    "        cx = (x + w / 2) / W\n",
    "        cy = (y + h / 2) / H\n",
    "        nw = w / W\n",
    "        nh = h / H\n",
    "        cls = cat_map[anno['category_id']]\n",
    "        lines.append(f'{cls} {cx:.6f} {cy:.6f} {nw:.6f} {nh:.6f}')\n",
    "    lbl_path.write_text('\\n'.join(lines))\n",
    "    written += 1\n",
    "\n",
    "print(f'Labels written: {written}, total: {len(list(LBL_DIR.iterdir()))}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Download Model Weights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from ultralytics import YOLO\n",
    "from pathlib import Path\n",
    "\n",
    "# yolo26n.pt — ultralytics will auto-download if not present\n",
    "if not Path('yolo26n.pt').exists():\n",
    "    print('Downloading yolo26n.pt...')\n",
    "    model = YOLO('yolo26n.pt')\n",
    "    import shutil\n",
    "    # Ultralytics saves to ~/.config/Ultralytics/ — copy to repo root\n",
    "    import glob\n",
    "    candidates = glob.glob('/root/.config/Ultralytics/yolo26n.pt') + \\\n",
    "                 glob.glob('/root/ultralytics/yolo26n.pt') + \\\n",
    "                 glob.glob('/content/yolo26n.pt')\n",
    "    for c in candidates:\n",
    "        shutil.copy(c, 'yolo26n.pt')\n",
    "        print(f'Copied from {c}')\n",
    "        break\n",
    "else:\n",
    "    print('yolo26n.pt already present.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Sweep Configuration\n",
    "\n",
    "Edit these variables to control the sweep."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Sweep settings ---\n",
    "ATTACKS          = 'fgsm,pgd,blur,deepfool'   # comma-separated\n",
    "DEFENSES         = 'median_preprocess'         # comma-separated, or 'none' to skip defense sweep\n",
    "MAX_IMAGES       = 500                         # 0 = all images\n",
    "VALIDATION       = True                        # compute mAP50 after each run\n",
    "SEED             = 42\n",
    "\n",
    "print('Attacks: ', ATTACKS)\n",
    "print('Defenses:', DEFENSES)\n",
    "print('Images:  ', MAX_IMAGES)\n",
    "print('Validate:', VALIDATION)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Run the Sweep"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys, os\n",
    "\n",
    "env = os.environ.copy()\n",
    "env['PYTHONPATH'] = 'src'\n",
    "\n",
    "cmd = [\n",
    "    sys.executable, 'scripts/sweep_and_report.py',\n",
    "    '--attacks',    ATTACKS,\n",
    "    '--defenses',   DEFENSES,\n",
    "    '--max-images', str(MAX_IMAGES),\n",
    "    '--seed',       str(SEED),\n",
    "    '--python-bin', sys.executable,\n",
    "    '--preset',     'full',\n",
    "]\n",
    "if VALIDATION:\n",
    "    cmd.append('--validation-enabled')\n",
    "\n",
    "print('Running:', ' '.join(cmd))\n",
    "print('-' * 60)\n",
    "\n",
    "result = subprocess.run(cmd, env=env)\n",
    "if result.returncode != 0:\n",
    "    print('\\nSweep failed with exit code', result.returncode)\n",
    "else:\n",
    "    print('\\nSweep complete.')"
   ]
  },
